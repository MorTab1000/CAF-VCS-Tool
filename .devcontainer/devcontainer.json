{
    "name": "CAF Engine Dev Environment",
    "build": {
        "dockerfile": "../deployment/Dockerfile"
    },
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash"
            },
            "extensions": [
                "ms-python.python",
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools"
            ]
        }
    },
    "postCreateCommand": "make deploy",
    "remoteUser": "root"
}